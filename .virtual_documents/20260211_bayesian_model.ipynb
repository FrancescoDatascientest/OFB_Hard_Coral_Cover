# -----------------------------
HC_last_reef = np.array([np.mean(HC[Ir == r]) for r in range(nreefs)])
HC_last_reef = np.log(HC_last_reef + 1)  # log pour cohérence avec le modèle

# -----------------------------
# Covariables futures par récif
# -----------------------------
HERB_future = np.array([np.mean(HERB[Ir == r]) for r in range(nreefs)])
CoTS_future = np.array([np.mean(CoTS[Ict == Ic[r]]) for r in range(nreefs)])
STORM_future = np.array([np.mean(STORM[Is == Is[r]]) for r in range(nreefs)])
BLEACH_future = np.array([np.mean(BLEACH[Ir == r]) for r in range(nreefs)])
DISEASE_future = np.array([np.mean(DISEASE[Ir == r]) for r in range(nreefs)])
UNK_future = np.array([np.mean(UNK[Ir == r]) for r in range(nreefs)])
WQ_future = np.array([np.mean(WQ[Ic == Ic[r]]) for r in range(nreefs)])
ZONE_future = np.array([np.mean(ZONE[Ir == r]) for r in range(nreefs)])

# -----------------------------
# Tableau pour stocker les prédictions
# -----------------------------
HC_future = np.zeros((n_samples, nreefs, n_years))

# -----------------------------
# Simulation année par année
# -----------------------------
for t, year in enumerate(years_future):
    print(f"Prédictions pour {year}...")
    
    for i in range(n_samples):
        # Récupérer les paramètres du posterior
        r_Reef_i = trace.posterior['r_Reef'].values.flatten()[i*nreefs:(i+1)*nreefs]
        a_Reef_i = trace.posterior['a_Reef'].values.flatten()[i*nreefs:(i+1)*nreefs]
        g2_i = trace.posterior['cots_'].values.flatten()  # shape = ncluster
        g3_i = trace.posterior['Cyclones'].values.flatten()  # shape = nshelf
        
        # Paramètres scalaires globaux
        g4_i = trace.posterior['Bleaching'].values.flatten()[i]
        g5_i = trace.posterior['Disease'].values.flatten()[i]
        g6_i = trace.posterior['Unknown'].values.flatten()[i]
        g7_i = trace.posterior['Herbivory'].values.flatten()[i]
        
        HC_pred_reef = np.zeros(nreefs)
        
        for r in range(nreefs):
            mu_i = (r_Reef_i[r] + g7_i * HERB_future[r]) + \
                   (1 - a_Reef_i[r]) * HC_last_reef[r] + \
                   g2_i[Ic[r]] * CoTS_future[r] + \
                   g3_i[Is[r]] * STORM_future[r] + \
                   g4_i * BLEACH_future[r] + \
                   g5_i * DISEASE_future[r] + \
                   g6_i * UNK_future[r]
            
            # Sigmoid → probabilité
            p_i = 1 / (1 + np.exp(-mu_i))
            
            # Binomial
            HC_pred_reef[r] = np.random.binomial(n=100, p=p_i)
        
        HC_future[i, :, t] = HC_pred_reef

    # Mettre à jour HC_last pour l'année suivante
    HC_last_reef = np.log(HC_future[:, :, t].mean(axis=0) + 1)

