years_future = [2027, 2028, 2029, 2030]
n_years = len(years_future)

nreefs = len(Reef)  # nombre de récifs

# Nombre d'échantillons = nombre de draws * chains
n_samples = trace.posterior['Bleaching'].values.size  # prend tous les scalaires

# -----------------------------
